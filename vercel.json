{
  "buildCommand": "npm run build",
  "framework": null,
  "functions": {
    "api/**/*": {
      "runtime": "nodejs18.x"
    },
    "pages/api/**/*": {
      "runtime": "nodejs18.x"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "redirects": [],
  "rewrites": []
}
